// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  ADMIN
  REGISTRAR
  STAFF
}

//////////////////////
// USER
//////////////////////

model User {
  // Internal DB ID
  id String @id @default(uuid())

  // Public / LGU User ID
  publicId String @unique

  name     String
  username String @unique
  password String
  email    String @unique

  role     UserRole
  office   String // e.g. "Civil Registry"
  metadata Json? // flexible user metadata

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  birthRecord BirthRecord[]
}

//////////////////////
// BIRTH CERTIFICATE
//////////////////////

model BirthRecord {
  id                 String @id @default(cuid())
  registryNo         String @unique
  dateOfRegistration String

  // Child Information
  childLastName   String
  childFirstName  String
  childMiddleName String?
  sex             String
  dateOfBirth     String
  placeOfBirth    String?
  isTwin          Boolean @default(false)
  birthOrder      String?

  // Mother Information
  motherLastName    String?
  motherFirstName   String?
  motherMiddleName  String?
  motherCitizenship String?

  // Father Information
  fatherLastName    String?
  fatherFirstName   String?
  fatherMiddleName  String?
  fatherCitizenship String?

  // Marriage Information
  dateOfMarriage  String?
  placeOfMarriage String?

  // Additional Information
  remarks            String?  @db.Text
  registrarName      String?
  signatureImagePath String? // Store file path instead of base64

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([registryNo])
  @@index([childLastName, childFirstName])
}
